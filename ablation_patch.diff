+  else if(e.key==='Home')goTo(0);
+  else if(e.key==='End')goTo(24);
+});
+let current=0,total=25;
+function go(d){goTo(current+d)}
+function goTo(n){
+  if(n<0)n=0;if(n>=total)n=total-1;current=n;
+  document.getElementById('deck').style.transform='translateX(-'+(n*100)+'vw)';
+  document.querySelectorAll('.dot').forEach((d,i)=>{d.classList.toggle('active',i===n)});
+  document.getElementById('page-num').textContent=String(n+1).padStart(2,'0')+' / '+String(total).padStart(2,'0');
+}
+</script>
